---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="site-title" aria-label="Oh KAY Gamers — Home">
			<img src="/images/ohkay-logo.png" alt="Oh KAY Gamers logo" class="site-logo" />
		</a>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/games">Games</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://github.com/Kayray1o1" target="_blank" rel="noopener" aria-label="Kay's GitHub profile">
				<svg viewBox="0 0 16 16" aria-hidden="true" width="24" height="24">
					<path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
				</svg>
			</a>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 1.5em;
		background: var(--bg-nav);
		border-bottom: 1px solid rgba(139, 0, 0, 0.3);
		box-shadow: 0 2px 20px rgba(0, 0, 0, 0.4);
		position: sticky;
		top: 0;
		z-index: 100;
	}

	.site-title {
		text-decoration: none;
		display: flex;
		align-items: center;
		flex-shrink: 0;
	}

	.site-logo {
		height: 38px;
		width: auto;
		object-fit: contain;
		border: none;
		border-radius: 0;
		transition: opacity 0.2s, filter 0.2s;
		display: block;
	}

	.site-title:hover .site-logo {
		opacity: 0.85;
		filter: drop-shadow(0 0 8px rgba(139,0,0,0.6));
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1em;
		height: 56px;
	}

	nav a {
		color: var(--gray-text);
		text-decoration: none;
		transition: color 0.2s;
	}

	nav a:hover {
		color: var(--white);
		text-shadow: none;
	}

	.internal-links {
		display: flex;
		gap: 0.25em;
	}

	.social-links,
	.social-links a {
		display: flex;
		align-items: center;
		gap: 0.5em;
		color: var(--gray-text);
	}

	.social-links a:hover {
		color: var(--accent);
	}

	@media (max-width: 480px) {
		.social-links { display: none; }
		.site-title { font-size: 1em; }
	}
</style>
