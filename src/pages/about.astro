---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="About | Oh KAY Gamers"
			description="Solo indie dev, writer, streamer — making narrative games with meaning."
		/>
	</head>
	<body>
		<Header />
		<main class="about-page">

			<!-- Hero -->
			<div class="page-header">
				<p class="eyebrow">The Person Behind the Games</p>
				<h1>Oh KAY Gamers</h1>
				<p class="subtitle">Solo dev. Writer. Streamer. Perpetually caffeinated.</p>
			</div>

			<!-- What is Oh KAY Gamers? -->
			<section class="section">
				<div class="section-label"><span>◈</span> The Name</div>
				<div class="content-card">
					<h2>What is Oh KAY Gamers?</h2>
					<p>
						The name is inspired by, one, my own name — and the pun behind it.
						I've never really seen myself as the best of gamers, but neither the worst.
						So being roughly in the middle is a safe space to hang out.
					</p>
					<p>
						I hope the games I make are far beyond <em>Oh KAY</em> — but right now,
						I'll happily settle for the title.
					</p>
					<a
						href="https://store.steampowered.com/curator/46022950"
						target="_blank"
						rel="noopener"
						class="btn btn-ghost"
					>
						<svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor" aria-hidden="true"><path d="M11.979 0C5.678 0 .511 4.86.022 11.037l6.432 2.658c.545-.371 1.203-.59 1.912-.59.063 0 .125.004.188.006l2.861-4.142V8.91c0-2.495 2.028-4.524 4.524-4.524 2.494 0 4.524 2.031 4.524 4.527s-2.03 4.525-4.524 4.525h-.105l-4.076 2.911c0 .052.004.105.004.159 0 1.875-1.515 3.396-3.39 3.396-1.635 0-3.016-1.173-3.331-2.727L.436 15.27C1.862 20.307 6.486 24 11.979 24c6.627 0 11.999-5.373 11.999-12S18.605 0 11.979 0zM7.54 18.21l-1.473-.61c.262.543.714.999 1.314 1.25 1.297.539 2.793-.076 3.332-1.375.263-.63.264-1.319.005-1.949s-.75-1.121-1.377-1.383c-.624-.26-1.29-.249-1.878-.03l1.523.63c.956.4 1.409 1.5 1.009 2.455-.397.957-1.497 1.41-2.455 1.012H7.54zm11.415-9.303c0-1.662-1.353-3.015-3.015-3.015-1.665 0-3.015 1.353-3.015 3.015 0 1.665 1.35 3.015 3.015 3.015 1.663 0 3.015-1.35 3.015-3.015zm-5.273-.005c0-1.252 1.013-2.266 2.265-2.266 1.249 0 2.266 1.014 2.266 2.266 0 1.251-1.017 2.265-2.266 2.265-1.252 0-2.265-1.014-2.265-2.265z"/></svg>
						See the Steam Curator Page
					</a>
				</div>
			</section>

			<!-- The Developer -->
			<section class="section">
				<div class="section-label"><span>◎</span> The Developer</div>
				<div class="content-card dev-card">
					<div class="dev-body">
						<img
							src="/images/kay-avatar.png"
							alt="Kay — illustrated avatar"
							class="avatar"
						/>
						<div class="dev-text">
							<h2>Hello, I'm Kay</h2>
							<p>
								Right now, I am a solo caffeine-addicted developer, and this is a passion project
								of mine — mostly self-funded. I am a writer, a streamer, and someone who fell head
								first into game development because it turns out making stories interactive is
								wildly addictive.
							</p>
							<p>
								If you enjoy what I'm building, I do have a
								<a href="https://ko-fi.com/kay1o1" target="_blank" rel="noopener" class="inline-link">Ko-Fi page</a>
								— buying me a coffee goes a long way at this stage and is truly appreciated.
							</p>
						</div>
						<div class="kofi-block">
							<a
								href="https://ko-fi.com/kay1o1"
								target="_blank"
								rel="noopener"
								class="btn btn-kofi"
							>
								<svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M23.881 8.948c-.773-4.085-4.859-4.593-4.859-4.593H.723c-.604 0-.679.798-.679.798s-.082 7.324-.022 11.822c.164 2.424 2.586 2.672 2.586 2.672s8.267-.023 11.966-.049c2.438-.426 2.683-2.566 2.658-3.734 4.352.24 7.422-2.831 6.649-6.916zm-11.062 3.511c-1.246 1.453-4.011 3.976-4.011 3.976s-.121.119-.31.019c-.59-.527-7.051-6.397-7.051-6.397-.998-.786-.842-2.522.227-3.21 1.069-.688 2.738-.134 3.182.803 0 0 3.912-3.548 5.29-3.18 1.378.368 1.944 1.733 1.403 2.985-.19.434-.667 1.867-1.73 3.004zm2.154 1.454c-.046-.327.293-.756.735-.756.441 0 .796.41.707.756-.09.345-.353.612-.707.612s-.635-.267-.735-.612zm3.585 2.189c-.427-.289-.614-.947-.414-1.51.2-.564.757-.828 1.184-.539.427.289.614.947.414 1.511-.199.564-.757.827-1.184.538zm2.309-1.975c-.207-.341-.12-.792.195-.951.314-.158.717.039.924.38.207.341.12.792-.195.951-.315.158-.717-.039-.924-.38z"/></svg>
								Buy Me a Coffee
							</a>
							<p class="kofi-note">Any and all support is truly appreciated.</p>
						</div>
					</div>
				</div>
			</section>

			<!-- The Goal -->
			<section class="section">
				<div class="section-label"><span>✦</span> The Goal</div>
				<div class="goal-card">
					<blockquote>
						"My main goal right now is to create an impactful story for people —
						horror or not, there should be meaning behind it."
					</blockquote>
				</div>
			</section>

			<!-- Find Me -->
			<section class="section">
				<div class="section-label"><span>◈</span> Find Me</div>
				<div class="social-grid">

					<a href="https://www.twitch.tv/kay_1o1" target="_blank" rel="noopener" class="social-card">
						<div class="social-icon twitch-icon">
							<svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor" aria-hidden="true"><path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714z"/></svg>
						</div>
						<div class="social-text">
							<span class="social-name">Twitch</span>
							<span class="social-handle">@kay_1o1</span>
						</div>
					</a>

					<a href="https://www.youtube.com/channel/UCjcrLUZnohe0ex3Y6v1s9eA" target="_blank" rel="noopener" class="social-card">
						<div class="social-icon youtube-icon">
							<svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
						</div>
						<div class="social-text">
							<span class="social-name">YouTube</span>
							<span class="social-handle">Oh KAY Gamers</span>
						</div>
					</a>

					<a href="https://discord.gg/USYpdHC55f" target="_blank" rel="noopener" class="social-card">
						<div class="social-icon discord-icon">
							<svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor" aria-hidden="true"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
						</div>
						<div class="social-text">
							<span class="social-name">Discord</span>
							<span class="social-handle">Join the Server</span>
						</div>
					</a>

					<a href="https://store.steampowered.com/curator/46022950" target="_blank" rel="noopener" class="social-card">
						<div class="social-icon steam-icon">
							<svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor" aria-hidden="true"><path d="M11.979 0C5.678 0 .511 4.86.022 11.037l6.432 2.658c.545-.371 1.203-.59 1.912-.59.063 0 .125.004.188.006l2.861-4.142V8.91c0-2.495 2.028-4.524 4.524-4.524 2.494 0 4.524 2.031 4.524 4.527s-2.03 4.525-4.524 4.525h-.105l-4.076 2.911c0 .052.004.105.004.159 0 1.875-1.515 3.396-3.39 3.396-1.635 0-3.016-1.173-3.331-2.727L.436 15.27C1.862 20.307 6.486 24 11.979 24c6.627 0 11.999-5.373 11.999-12S18.605 0 11.979 0z"/></svg>
						</div>
						<div class="social-text">
							<span class="social-name">Steam</span>
							<span class="social-handle">Curator Page</span>
						</div>
					</a>

					<a href="https://ko-fi.com/kay1o1" target="_blank" rel="noopener" class="social-card kofi-card">
						<div class="social-icon kofi-icon">
							<svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor" aria-hidden="true"><path d="M23.881 8.948c-.773-4.085-4.859-4.593-4.859-4.593H.723c-.604 0-.679.798-.679.798s-.082 7.324-.022 11.822c.164 2.424 2.586 2.672 2.586 2.672s8.267-.023 11.966-.049c2.438-.426 2.683-2.566 2.658-3.734 4.352.24 7.422-2.831 6.649-6.916zm-11.062 3.511c-1.246 1.453-4.011 3.976-4.011 3.976s-.121.119-.31.019c-.59-.527-7.051-6.397-7.051-6.397-.998-.786-.842-2.522.227-3.21 1.069-.688 2.738-.134 3.182.803 0 0 3.912-3.548 5.29-3.18 1.378.368 1.944 1.733 1.403 2.985-.19.434-.667 1.867-1.73 3.004z"/></svg>
						</div>
						<div class="social-text">
							<span class="social-name">Ko-Fi</span>
							<span class="social-handle">Buy Me a Coffee</span>
						</div>
					</a>

				</div>
			</section>

		</main>
		<Footer />
	</body>
</html>

<style>
	.about-page {
		width: 860px;
		max-width: calc(100% - 2em);
		margin: auto;
		padding: 0 1em 5em;
	}

	/* ── Page Header ── */
	.page-header {
		text-align: center;
		padding: 5em 1em 3.5em;
		border-bottom: 1px solid rgba(139,0,0,0.15);
		margin-bottom: 3.5em;
	}

	.eyebrow {
		font-family: 'Cinzel', Georgia, serif;
		font-size: 0.72em;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--accent);
		margin: 0 0 0.8em;
	}

	.page-header h1 {
		font-size: 3.5em;
		margin: 0 0 0.3em;
		text-shadow: 0 0 40px rgba(139,0,0,0.25);
	}

	.subtitle {
		font-size: 1em;
		color: var(--gray-text);
		margin: 0;
		font-style: italic;
	}

	/* ── Section ── */
	.section {
		margin-bottom: 3.5em;
	}

	.section-label {
		display: flex;
		align-items: center;
		gap: 0.5em;
		font-family: 'Cinzel', Georgia, serif;
		font-size: 0.7em;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 1.2em;
		padding-bottom: 0.6em;
		border-bottom: 1px solid rgba(139,0,0,0.15);
	}

	/* ── Content Cards ── */
	.content-card {
		background: var(--bg-card);
		border: 1px solid rgba(139,0,0,0.2);
		border-radius: 10px;
		padding: 2.2em;
	}

	.content-card h2 {
		font-size: 1.7em;
		margin: 0 0 0.8em;
	}

	.content-card p {
		font-size: 1em;
		line-height: 1.8;
		color: var(--gray-text);
		margin-bottom: 1em;
	}

	.content-card p:last-of-type {
		margin-bottom: 1.5em;
	}

	.content-card p em {
		color: var(--accent-bright);
		font-style: italic;
	}

	.inline-link {
		color: var(--accent-bright);
		text-decoration: underline;
		text-decoration-color: rgba(185,28,28,0.4);
		text-underline-offset: 3px;
	}

	.inline-link:hover {
		color: #e74c3c;
		text-shadow: none;
	}

	/* ── Dev Card ── */
	.avatar {
		width: 140px;
		height: 140px;
		border-radius: 50%;
		object-fit: cover;
		border: 2px solid rgba(139,0,0,0.4);
		flex-shrink: 0;
		align-self: center;
	}

	.dev-body {
		display: flex;
		gap: 2em;
		align-items: flex-start;
		flex-wrap: wrap;
	}

	.dev-text {
		flex: 1;
		min-width: 260px;
	}

	.dev-text h2 {
		font-size: 1.7em;
		margin: 0 0 0.8em;
	}

	.dev-text p {
		font-size: 1em;
		line-height: 1.8;
		color: var(--gray-text);
		margin-bottom: 1em;
	}

	.kofi-block {
		flex-shrink: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.6em;
		padding: 1.5em;
		background: rgba(255,94,72,0.05);
		border: 1px solid rgba(255,94,72,0.15);
		border-radius: 8px;
		text-align: center;
		min-width: 180px;
	}

	.kofi-note {
		font-size: 0.78em;
		color: rgba(154,128,128,0.7);
		margin: 0;
		font-style: italic;
		max-width: 160px;
	}

	/* ── Goal / Blockquote Card ── */
	.goal-card {
		padding: 0.5em 0;
	}

	.goal-card blockquote {
		border-left: 3px solid var(--accent);
		padding: 1em 1.5em 1em 2em;
		background: rgba(139,0,0,0.05);
		border-radius: 0 10px 10px 0;
		font-size: 1.2em;
		font-style: italic;
		color: var(--white);
		line-height: 1.7;
		margin: 0;
	}

	/* ── Social Grid ── */
	.social-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
		gap: 1em;
	}

	.social-card {
		display: flex;
		align-items: center;
		gap: 1em;
		padding: 1.2em 1.4em;
		background: var(--bg-card);
		border: 1px solid rgba(139,0,0,0.15);
		border-radius: 8px;
		text-decoration: none;
		transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
	}

	.social-card:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(0,0,0,0.4);
		text-shadow: none;
	}

	.social-icon {
		width: 42px;
		height: 42px;
		border-radius: 8px;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}

	.twitch-icon  { background: rgba(145,70,255,0.15); color: #9146ff; }
	.youtube-icon { background: rgba(255,0,0,0.12);    color: #ff4444; }
	.discord-icon { background: rgba(88,101,242,0.15); color: #5865f2; }
	.steam-icon   { background: rgba(199,213,224,0.1); color: #c7d5e0; }
	.kofi-icon    { background: rgba(255,94,72,0.12);  color: #ff5e48; }

	.social-card:hover .twitch-icon  { background: rgba(145,70,255,0.25); }
	.social-card:hover .youtube-icon { background: rgba(255,0,0,0.22); }
	.social-card:hover .discord-icon { background: rgba(88,101,242,0.25); }
	.social-card:hover .steam-icon   { background: rgba(199,213,224,0.18); }
	.social-card:hover .kofi-icon    { background: rgba(255,94,72,0.22); }

	.social-text {
		display: flex;
		flex-direction: column;
		gap: 0.15em;
	}

	.social-name {
		font-family: 'Cinzel', Georgia, serif;
		font-size: 0.85em;
		font-weight: 700;
		color: var(--white);
		letter-spacing: 0.04em;
	}

	.social-handle {
		font-size: 0.78em;
		color: var(--gray-text);
	}

	/* ── Buttons ── */
	.btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5em;
		padding: 0.65em 1.4em;
		border-radius: 6px;
		font-family: 'Cinzel', Georgia, serif;
		font-size: 0.8em;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-decoration: none;
		transition: all 0.2s;
		white-space: nowrap;
	}

	.btn-ghost {
		background: transparent;
		color: var(--gray-text);
		border: 1px solid rgba(139,0,0,0.3);
	}
	.btn-ghost:hover {
		border-color: var(--accent);
		color: var(--white);
		text-shadow: none;
	}

	.btn-kofi {
		background: rgba(255,94,72,0.1);
		color: #ff5e48;
		border: 1px solid rgba(255,94,72,0.3);
	}
	.btn-kofi:hover {
		background: rgba(255,94,72,0.2);
		color: #ff5e48;
		box-shadow: 0 0 14px rgba(255,94,72,0.2);
		text-shadow: none;
	}

	/* ── Responsive ── */
	@media (max-width: 600px) {
		.page-header h1 { font-size: 2.5em; }
		.dev-body { flex-direction: column; align-items: center; }
		.avatar { width: 120px; height: 120px; }
		.kofi-block { width: 100%; min-width: unset; }
		.social-grid { grid-template-columns: 1fr 1fr; }
	}

	@media (max-width: 400px) {
		.social-grid { grid-template-columns: 1fr; }
	}
</style>
