---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Games | Oh KAY Gamers" description="Indie horror games by Oh KAY Gamers — psychological dread, survival terror, and more." />
	</head>
	<body>
		<Header />
		<main class="games-page">

			<!-- Page Header -->
			<div class="page-header">
				<p class="eyebrow">Oh KAY Gamers</p>
				<h1>The Games</h1>
				<p class="subtitle">Indie horror — built from fear, atmosphere, and too many sleepless nights.</p>
			</div>

			<!-- ─── FLAGSHIP: Paranoia Vol. I ─── -->
			<section class="section">
				<div class="section-label">
					<span class="label-icon">⬡</span> Flagship Title
				</div>

				<div class="card featured-card">
					<div class="featured-glow"></div>
					<img
						src="/images/paranoia-cover.png"
						alt="Paranoia Vol. I — game cover"
						class="paranoia-cover"
					/>
					<div class="featured-body">
						<div class="badge-row">
							<span class="badge badge-steam">
								<svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor" aria-hidden="true"><path d="M11.979 0C5.678 0 .511 4.86.022 11.037l6.432 2.658c.545-.371 1.203-.59 1.912-.59.063 0 .125.004.188.006l2.861-4.142V8.91c0-2.495 2.028-4.524 4.524-4.524 2.494 0 4.524 2.031 4.524 4.527s-2.03 4.525-4.524 4.525h-.105l-4.076 2.911c0 .052.004.105.004.159 0 1.875-1.515 3.396-3.39 3.396-1.635 0-3.016-1.173-3.331-2.727L.436 15.27C1.862 20.307 6.486 24 11.979 24c6.627 0 11.999-5.373 11.999-12S18.605 0 11.979 0zM7.54 18.21l-1.473-.61c.262.543.714.999 1.314 1.25 1.297.539 2.793-.076 3.332-1.375.263-.63.264-1.319.005-1.949s-.75-1.121-1.377-1.383c-.624-.26-1.29-.249-1.878-.03l1.523.63c.956.4 1.409 1.5 1.009 2.455-.397.957-1.497 1.41-2.455 1.012H7.54zm11.415-9.303c0-1.662-1.353-3.015-3.015-3.015-1.665 0-3.015 1.353-3.015 3.015 0 1.665 1.35 3.015 3.015 3.015 1.663 0 3.015-1.35 3.015-3.015zm-5.273-.005c0-1.252 1.013-2.266 2.265-2.266 1.249 0 2.266 1.014 2.266 2.266 0 1.251-1.017 2.265-2.266 2.265-1.252 0-2.265-1.014-2.265-2.265z"/></svg>
								Steam
							</span>
							<span class="badge badge-status-wishlist">Wishlist Now</span>
						</div>

						<h2 class="game-title">Paranoia <span class="vol">Vol. I</span></h2>
						<p class="game-desc">
							<!-- KAY — drop your one-paragraph game description here -->
							A psychological horror experience that pushes you to question what is real and what your mind has invented. Coming to Steam.
						</p>

						<div class="btn-row">
							<a
								href="https://store.steampowered.com/app/4503610/Paranoia_Vol_I/"
								target="_blank"
								rel="noopener"
								class="btn btn-primary"
							>
								<svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M11.979 0C5.678 0 .511 4.86.022 11.037l6.432 2.658c.545-.371 1.203-.59 1.912-.59.063 0 .125.004.188.006l2.861-4.142V8.91c0-2.495 2.028-4.524 4.524-4.524 2.494 0 4.524 2.031 4.524 4.527s-2.03 4.525-4.524 4.525h-.105l-4.076 2.911c0 .052.004.105.004.159 0 1.875-1.515 3.396-3.39 3.396-1.635 0-3.016-1.173-3.331-2.727L.436 15.27C1.862 20.307 6.486 24 11.979 24c6.627 0 11.999-5.373 11.999-12S18.605 0 11.979 0z"/></svg>
								Wishlist on Steam
							</a>
							<a
								href="https://store.steampowered.com/app/4658380/Paranoia_Vol_I_Demo/"
								target="_blank"
								rel="noopener"
								class="btn btn-ghost"
							>
								Play the Demo
							</a>
						</div>
					</div>
				</div>
			</section>

			<!-- ─── RELEASED: itch.io games ─── -->
			<section class="section">
				<div class="section-label">
					<span class="label-icon">◈</span> Released
				</div>

				<div class="games-grid">

					<div class="card game-card">
						<div class="badge-row">
							<span class="badge badge-itch">
								<svg viewBox="0 0 245 240" width="12" height="12" fill="currentColor" aria-hidden="true"><path d="M31.99 1.365C21.287 7.72.2 31.945 0 38.298v10c0 12.85 12.018 24.2 23.02 24.2 13.516 0 24.57-11.39 24.57-24.9 0 13.51 10.507 24.9 24.023 24.9 13.517 0 24.024-11.39 24.024-24.9 0 13.51 11.054 24.9 24.571 24.9h.5c13.517 0 24.57-11.39 24.57-24.9 0 13.51 10.507 24.9 24.023 24.9 13.517 0 24.023-11.39 24.023-24.9 0 13.51 11.055 24.9 24.572 24.9 11 0 23.02-11.35 23.02-24.2v-10c-.2-6.353-21.287-30.578-32-36.933C185.986.997 156.816.005 122.5 0 88.185.005 59.016.997 31.99 1.365zm60.856 84.08c-3.62 12.577-8.298 23.913-19.334 32.73C60.699 128.1 34.97 133.847 8.5 124.96v67.517c0 15.35 13.486 36.523 29 36.523h151c15.515 0 29-21.174 29-36.523V124.96c-26.47 8.888-52.2 3.14-65.012-6.785-11.036-8.817-15.714-20.153-19.334-32.73-.527-.024-1.056-.037-1.587-.037-.527 0-1.056.013-1.583.037z"/></svg>
								itch.io
							</span>
							<span class="badge badge-released">Released</span>
						</div>
						<h3 class="game-title">She's Lost Here</h3>
						<p class="game-desc">
							<!-- KAY — add a short description for this game -->
							A horror experience available now on itch.io.
						</p>
						<a
							href="https://oh-kay-gamers.itch.io/shes-lost-here"
							target="_blank"
							rel="noopener"
							class="btn btn-itch"
						>Play on itch.io →</a>
					</div>

					<div class="card game-card">
						<div class="badge-row">
							<span class="badge badge-itch">
								<svg viewBox="0 0 245 240" width="12" height="12" fill="currentColor" aria-hidden="true"><path d="M31.99 1.365C21.287 7.72.2 31.945 0 38.298v10c0 12.85 12.018 24.2 23.02 24.2 13.516 0 24.57-11.39 24.57-24.9 0 13.51 10.507 24.9 24.023 24.9 13.517 0 24.024-11.39 24.024-24.9 0 13.51 11.054 24.9 24.571 24.9h.5c13.517 0 24.57-11.39 24.57-24.9 0 13.51 10.507 24.9 24.023 24.9 13.517 0 24.023-11.39 24.023-24.9 0 13.51 11.055 24.9 24.572 24.9 11 0 23.02-11.35 23.02-24.2v-10c-.2-6.353-21.287-30.578-32-36.933C185.986.997 156.816.005 122.5 0 88.185.005 59.016.997 31.99 1.365zm60.856 84.08c-3.62 12.577-8.298 23.913-19.334 32.73C60.699 128.1 34.97 133.847 8.5 124.96v67.517c0 15.35 13.486 36.523 29 36.523h151c15.515 0 29-21.174 29-36.523V124.96c-26.47 8.888-52.2 3.14-65.012-6.785-11.036-8.817-15.714-20.153-19.334-32.73-.527-.024-1.056-.037-1.587-.037-.527 0-1.056.013-1.583.037z"/></svg>
								itch.io
							</span>
							<span class="badge badge-released">Released</span>
						</div>
						<h3 class="game-title">My Growing Nightmares</h3>
						<p class="game-desc">
							<!-- KAY — add a short description for this game -->
							A horror experience available now on itch.io.
						</p>
						<a
							href="https://oh-kay-gamers.itch.io/my-growing-nightmares"
							target="_blank"
							rel="noopener"
							class="btn btn-itch"
						>Play on itch.io →</a>
					</div>

				</div>
			</section>

			<!-- ─── IN DEVELOPMENT ─── -->
			<section class="section">
				<div class="section-label">
					<span class="label-icon">◎</span> In Development
				</div>

				<div class="games-grid">
					<div class="card game-card dev-card">
						<div class="badge-row">
							<span class="badge badge-dev">In Development</span>
						</div>
						<h3 class="game-title">Shadow Guardian</h3>
						<p class="game-desc">
							<!-- KAY — add a short description / teaser here -->
							Something is watching. More details coming soon.
						</p>
						<p class="dev-update">Follow the blog for development updates.</p>
					</div>
				</div>
			</section>

			<!-- ─── ON THE HORIZON ─── -->
			<section class="section horizon-section">
				<div class="horizon-inner">
					<p class="eyebrow">What's Next</p>
					<h2>More in the Works</h2>
					<p class="horizon-body">
						New games, interactive stories, and other creative projects are always
						brewing in the background — games, narratives, and things that are harder to categorise.
						Check the blog for updates, dev logs, and the occasional peek behind the curtain.
					</p>
					<a href="/blog" class="btn btn-ghost">Read the Dev Blog →</a>
				</div>
			</section>

		</main>
		<Footer />
	</body>
</html>

<style>
	.games-page {
		width: 900px;
		max-width: calc(100% - 2em);
		margin: auto;
		padding: 3em 1em 5em;
	}

	/* ── Page Header ── */
	.page-header {
		text-align: center;
		padding: 2em 0 3.5em;
		border-bottom: 1px solid rgba(139,0,0,0.2);
		margin-bottom: 3em;
	}

	.eyebrow {
		font-family: 'Cinzel', Georgia, serif;
		font-size: 0.75em;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--accent);
		margin: 0 0 0.6em;
	}

	.page-header h1 {
		font-size: 3.5em;
		margin: 0 0 0.3em;
		text-shadow: 0 0 40px rgba(139,0,0,0.3);
	}

	.subtitle {
		font-size: 1.05em;
		color: var(--gray-text);
		max-width: 520px;
		margin: 0 auto;
	}

	/* ── Section ── */
	.section {
		margin-bottom: 4em;
	}

	.section-label {
		display: flex;
		align-items: center;
		gap: 0.5em;
		font-family: 'Cinzel', Georgia, serif;
		font-size: 0.7em;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 1.2em;
		padding-bottom: 0.6em;
		border-bottom: 1px solid rgba(139,0,0,0.15);
	}

	.label-icon {
		font-size: 1.1em;
		opacity: 0.7;
	}

	/* ── Cards ── */
	.card {
		background: var(--bg-card);
		border: 1px solid rgba(139,0,0,0.2);
		border-radius: 10px;
		padding: 2em;
		transition: border-color 0.25s, box-shadow 0.25s;
	}

	.card:hover {
		border-color: rgba(139,0,0,0.5);
		box-shadow: 0 4px 30px rgba(139,0,0,0.15);
	}

	/* ── Featured Card ── */
	.featured-card {
		position: relative;
		overflow: hidden;
		padding: 0;
		border-color: rgba(139,0,0,0.4);
		background: linear-gradient(135deg, #0a0000 0%, #050000 100%);
	}

	.paranoia-cover {
		width: 100%;
		height: 200px;
		object-fit: cover;
		object-position: center;
		display: block;
		border-radius: 9px 9px 0 0;
		border: none;
		margin: 0;
	}

	.featured-body {
		padding: 2em 2.5em 2.5em;
	}

	.featured-glow {
		position: absolute;
		top: -60px;
		right: -60px;
		width: 300px;
		height: 300px;
		background: radial-gradient(circle, rgba(139,0,0,0.12) 0%, transparent 70%);
		pointer-events: none;
	}

	.featured-body {
		position: relative;
		z-index: 1;
		max-width: 620px;
	}

	.featured-card h2.game-title {
		font-size: 2.8em;
		margin: 0.3em 0 0.5em;
		text-shadow: 0 0 30px rgba(139,0,0,0.4);
	}

	.featured-card .game-desc {
		font-size: 1.05em;
		line-height: 1.75;
		margin-bottom: 1.8em;
		max-width: 560px;
	}

	.vol {
		color: var(--accent);
	}

	/* ── Grid ── */
	.games-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 1.5em;
	}

	.game-card h3.game-title {
		font-size: 1.5em;
		margin: 0.4em 0 0.6em;
	}

	.game-desc {
		font-size: 0.95em;
		color: var(--gray-text);
		margin-bottom: 1.4em;
		line-height: 1.65;
	}

	/* ── Dev card ── */
	.dev-card {
		border-style: dashed;
		border-color: rgba(139,0,0,0.25);
		background: rgba(8,0,0,0.6);
	}

	.dev-update {
		font-size: 0.82em;
		color: rgba(154,128,128,0.6);
		font-style: italic;
		margin: 0;
	}

	/* ── Badge Row ── */
	.badge-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5em;
		margin-bottom: 0.5em;
	}

	.badge {
		display: inline-flex;
		align-items: center;
		gap: 0.35em;
		font-size: 0.7em;
		font-family: 'Cinzel', Georgia, serif;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		padding: 0.25em 0.7em;
		border-radius: 4px;
		font-weight: 700;
	}

	.badge-steam   { background: rgba(27,40,56,0.8); color: #c7d5e0; border: 1px solid rgba(199,213,224,0.2); }
	.badge-itch    { background: rgba(250,84,70,0.15); color: #fa5446; border: 1px solid rgba(250,84,70,0.3); }
	.badge-released { background: rgba(34,197,94,0.12); color: #4ade80; border: 1px solid rgba(34,197,94,0.25); }
	.badge-dev     { background: rgba(234,179,8,0.12); color: #fbbf24; border: 1px solid rgba(234,179,8,0.25); }
	.badge-status-wishlist { background: rgba(139,0,0,0.2); color: #e87070; border: 1px solid rgba(139,0,0,0.4); }

	/* ── Buttons ── */
	.btn-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8em;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5em;
		padding: 0.65em 1.4em;
		border-radius: 6px;
		font-family: 'Cinzel', Georgia, serif;
		font-size: 0.8em;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-decoration: none;
		transition: all 0.2s;
		cursor: pointer;
		white-space: nowrap;
	}

	.btn-primary {
		background: var(--accent);
		color: var(--white);
		border: 1px solid rgba(185,28,28,0.6);
	}
	.btn-primary:hover {
		background: var(--accent-bright);
		color: var(--white);
		box-shadow: 0 0 18px rgba(139,0,0,0.5);
		text-shadow: none;
	}

	.btn-ghost {
		background: transparent;
		color: var(--gray-text);
		border: 1px solid rgba(139,0,0,0.3);
	}
	.btn-ghost:hover {
		border-color: var(--accent);
		color: var(--white);
		text-shadow: none;
	}

	.btn-itch {
		background: rgba(250,84,70,0.1);
		color: #fa5446;
		border: 1px solid rgba(250,84,70,0.3);
	}
	.btn-itch:hover {
		background: rgba(250,84,70,0.2);
		color: #fa5446;
		box-shadow: 0 0 14px rgba(250,84,70,0.2);
		text-shadow: none;
	}

	/* ── Horizon Section ── */
	.horizon-section {
		margin-top: 2em;
	}

	.horizon-inner {
		text-align: center;
		padding: 3em 2em;
		background: linear-gradient(135deg, rgba(139,0,0,0.06) 0%, transparent 60%);
		border: 1px solid rgba(139,0,0,0.15);
		border-radius: 12px;
	}

	.horizon-inner h2 {
		font-size: 2em;
		margin: 0.3em 0 0.7em;
	}

	.horizon-body {
		max-width: 500px;
		margin: 0 auto 1.8em;
		font-size: 0.95em;
		line-height: 1.75;
	}

	/* ── Responsive ── */
	@media (max-width: 600px) {
		.games-grid { grid-template-columns: 1fr; }
		.page-header h1 { font-size: 2.4em; }
		.featured-card h2.game-title { font-size: 2em; }
		.btn-row { flex-direction: column; }
	}
</style>
