---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import FormattedDate from '../../../components/FormattedDate.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	const categories = [...new Set(posts.map(p => p.data.category).filter(Boolean))];

	return categories.map(category => {
		const slug = category.toLowerCase().replace(/\s+/g, '-');
		const filtered = posts
			.filter(p => p.data.category === category)
			.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
		return {
			params: { category: slug },
			props: { categoryName: category, posts: filtered },
		};
	});
}

const { categoryName, posts } = Astro.props;

// Build chip list (all categories) for navigation between them
const allPosts = await getCollection('blog');
const allCategories = [...new Set(allPosts.map(p => p.data.category).filter(Boolean))]
	.map(name => ({
		name,
		slug: name.toLowerCase().replace(/\s+/g, '-'),
		count: allPosts.filter(p => p.data.category === name).length,
	}));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`${categoryName} | Oh KAY Gamers`}
			description={`All ${categoryName} posts from Oh KAY Gamers — narrative-driven indie horror coverage.`}
		/>
	</head>
	<body>
		<Header />
		<main class="blog-page">
			<div class="blog-header">
				<p class="eyebrow">Category</p>
				<h1>{categoryName}</h1>
				<p class="subtitle">{posts.length} {posts.length === 1 ? 'post' : 'posts'}</p>
			</div>

			<!-- Category Chips -->
			<nav class="category-chips" aria-label="Browse by category">
				<a href="/blog/" class="chip">All Posts <span class="chip-count">({allPosts.length})</span></a>
				{allCategories.map(cat => (
					<a
						href={`/blog/category/${cat.slug}/`}
						class={`chip ${cat.name === categoryName ? 'chip-active' : ''}`}
					>
						{cat.name} <span class="chip-count">({cat.count})</span>
					</a>
				))}
			</nav>

			<ul class="post-list">
				{posts.map((post) => (
					<li>
						<a href={`/blog/${post.id}/`} class="post-card">
							{post.data.heroImage && (
								<div class="post-thumb">
									<img src={post.data.heroImage.src} alt={post.data.title} />
								</div>
							)}
							<div class="post-info">
								{post.data.category && (
									<a
										href={`/blog/category/${post.data.category.toLowerCase().replace(/\s+/g, '-')}/`}
										class="post-category"
										onclick="event.stopPropagation()"
									>{post.data.category}</a>
								)}
								<h2 class="post-title">{post.data.title}</h2>
								<p class="post-desc">{post.data.description}</p>
								<p class="post-date"><FormattedDate date={post.data.pubDate} /></p>
								{post.data.tags && (
									<div class="post-tags">
										{post.data.tags.slice(0, 4).map(tag => (
											<span class="tag">{tag}</span>
										))}
									</div>
								)}
							</div>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>

<style>
	.blog-page {
		width: 860px;
		max-width: calc(100% - 2em);
		margin: auto;
		padding: 0 1em 5em;
	}

	.blog-header {
		text-align: center;
		padding: 4em 1em 2em;
		border-bottom: 1px solid rgba(139,0,0,0.15);
		margin-bottom: 2em;
	}

	.eyebrow {
		font-family: 'Cinzel', Georgia, serif;
		font-size: 0.72em;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--accent);
		margin: 0 0 0.8em;
	}

	.blog-header h1 {
		font-size: 3.2em;
		margin: 0 0 0.4em;
		text-shadow: 0 0 40px rgba(139,0,0,0.2);
	}

	.subtitle {
		font-size: 0.95em;
		color: var(--gray-text);
		margin: 0;
		font-style: italic;
		opacity: 0.7;
	}

	/* ── Category Chips ── */
	.category-chips {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5em;
		justify-content: center;
		margin-bottom: 2.8em;
		padding: 0 0.5em;
	}

	.chip {
		font-family: 'Cinzel', Georgia, serif;
		font-size: 0.7em;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		padding: 0.6em 1.2em;
		border-radius: 4px;
		border: 1px solid rgba(139,0,0,0.3);
		color: var(--gray-text);
		background: transparent;
		text-decoration: none;
		transition: border-color 0.2s, color 0.2s, background 0.2s, box-shadow 0.2s;
		font-weight: 700;
		white-space: nowrap;
	}

	.chip:hover {
		border-color: var(--accent);
		color: var(--white);
		text-shadow: none;
	}

	.chip-active {
		background: var(--accent);
		color: var(--white);
		border-color: rgba(185,28,28,0.6);
		box-shadow: 0 0 14px rgba(139,0,0,0.25);
	}

	.chip-active:hover {
		background: var(--accent-bright);
		color: var(--white);
	}

	.chip-count {
		opacity: 0.55;
		font-size: 0.85em;
		margin-left: 0.3em;
		font-weight: 400;
	}

	/* ── Post List (mirrors /blog) ── */
	.post-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1.8em;
	}

	.post-card {
		display: flex;
		gap: 1.8em;
		background: var(--bg-card);
		border: 1px solid rgba(139,0,0,0.15);
		border-radius: 10px;
		padding: 1.6em;
		text-decoration: none;
		transition: border-color 0.25s, box-shadow 0.25s;
	}

	.post-card:hover {
		border-color: rgba(139,0,0,0.4);
		box-shadow: 0 4px 24px rgba(139,0,0,0.1);
	}

	.post-thumb {
		flex-shrink: 0;
		width: 180px;
		height: 120px;
		border-radius: 6px;
		overflow: hidden;
	}

	.post-thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.post-info {
		display: flex;
		flex-direction: column;
		gap: 0.4em;
	}

	.post-category {
		font-family: 'Cinzel', Georgia, serif;
		font-size: 0.65em;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--accent);
		text-decoration: none;
		align-self: flex-start;
		padding: 0.15em 0.5em;
		margin-left: -0.5em;
		border-radius: 3px;
		transition: background 0.2s, color 0.2s;
	}

	.post-category:hover {
		background: rgba(139,0,0,0.15);
		color: var(--white);
		text-shadow: none;
	}

	.post-title {
		font-size: 1.3em;
		margin: 0;
		color: var(--white);
	}

	.post-desc {
		font-size: 0.9em;
		color: var(--gray-text);
		line-height: 1.6;
		margin: 0;
	}

	.post-date {
		font-size: 0.78em;
		color: var(--gray-text);
		opacity: 0.6;
		margin: 0;
	}

	.post-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4em;
		margin-top: 0.2em;
	}

	.tag {
		font-size: 0.68em;
		padding: 0.2em 0.7em;
		border: 1px solid rgba(139,0,0,0.3);
		border-radius: 4px;
		color: var(--accent);
		background: rgba(139,0,0,0.06);
	}

	@media (max-width: 600px) {
		.post-card { flex-direction: column; }
		.post-thumb { width: 100%; height: 180px; }
		.blog-header h1 { font-size: 2.4em; }
		.chip { font-size: 0.65em; padding: 0.5em 1em; }
	}
</style>
